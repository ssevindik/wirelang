{
  "compilerOptions": {
    "rootDir": "./core",
    "outDir": "./dist",
    "module": "Node16",
    "target": "ES2020",
    "types": ["node"],
    "esModuleInterop": true,
    "moduleResolution": "node16",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["core/**/*"],
  "exclude": ["node_modules", "dist", "playground.ts"]
}
